│   │   │   ├── my_courses.html
│   │   │   └── student_list.html
│   │   └── common/               # 公共页面
│   │       ├── 403.html          # 无权限页面
│   │       └── 404.html          # 页面不存在
│   ├── static/                   # 静态资源
│   │   ├── css/                  # 样式文件
│   │   ├── js/                   # JavaScript文件
│   │   ├── images/               # 图片资源
│   │   └── lib/                  # 第三方库(Bootstrap、jQuery)
│   ├── utils/                    # 工具函数
│   │   ├── __init__.py
│   │   ├── md5.py                # MD5加密工具
│   │   ├── decorators.py         # 权限装饰器
│   │   └── excel.py              # Excel导出工具
│   └── extensions.py             # 扩展初始化(SQLAlchemy等)
├── migrations/                   # 数据库迁移文件(Flask-Migrate)
├── tests/                        # 测试用例(可选)
├── run.py                        # 应用启动入口
├── requirements.txt              # 依赖包列表
└── README.md                     # 项目说明文档
