│   │   ├── grade.py              # 成绩模型
│   │   └── schedule.py           # 排课模型
│   ├── blueprints/               # 蓝图(按功能模块划分)
│   │   ├── __init__.py
│   │   ├── auth.py               # 登录/注册/权限认证
│   │   ├── admin.py              # 管理员后台
│   │   ├── student.py            # 学生功能
│   │   ├── teacher.py            # 教师功能
