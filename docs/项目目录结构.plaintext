│   │   ├── grade.py              # 成绩管理
│   │   └── schedule.py           # 排课管理
│   ├── templates/                # HTML模板
│   │   ├── base.html             # 基础模板(导航栏、页脚)
│   │   ├── auth/                 # 认证相关页面
│   │   │   ├── login.html
│   │   │   └── register.html
│   │   ├── admin/                # 管理员页面
│   │   │   ├── index.html
│   │   │   ├── student_list.html
│   │   │   ├── teacher_list.html
│   │   │   └── course_list.html
